{
  "schema_version": "1.2",
  "id": "interpolate_30fps",
  "name": "Interpolate 30fps",
  "description": "Confirm selected videos in a compact Qt shell, then interpolate to 30fps in a console flow.",
  "author": "ContextHub",
  "version": "1.1.0",
  "icon": "icon.png",
  "runtime": {
    "category": "video",
    "python_version": "3.11",
    "required_binaries": [
      "ffmpeg"
    ]
  },
  "execution": {
    "entry_point": "main.py",
    "arguments": "",
    "mode": "console",
    "working_directory": "./",
    "auto_start": false,
    "run_as_admin": false,
    "single_instance": false,
    "env_vars": {}
  },
  "monitoring": {
    "enabled": false,
    "type": "process",
    "target": "interpolate_30fps",
    "interval": 5000,
    "on_active": null,
    "on_inactive": null,
    "on_error": null
  },
  "triggers": {
    "tray": false,
    "quick_launcher": false,
    "context_menu": {
      "enabled": true,
      "extensions": [
        ".mp4",
        ".mov",
        ".avi",
        ".mkv"
      ],
      "scopes": []
    },
    "sidebar_widget": null
  },
  "ui": {
    "enabled": true,
    "framework": "qt",
    "shared_theme": "contexthub"
  }
}
