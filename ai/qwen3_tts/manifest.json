{
  "schema_version": "1.2",
  "id": "qwen3_tts",
  "name": "Qwen3 TTS",
  "description": "Generate speech with Qwen3-TTS custom voice or voice clone.",
  "author": "ContextHub",
  "version": "1.0.1",
  "icon": null,
  "runtime": {
    "category": "ai",
    "python_version": "3.12",
    "required_binaries": []
  },
  "execution": {
    "entry_point": "main.py",
    "arguments": "",
    "mode": "gui",
    "working_directory": "./",
    "auto_start": false,
    "run_as_admin": false,
    "single_instance": false,
    "env_vars": {}
  },
  "monitoring": {
    "enabled": false,
    "type": "process",
    "target": "qwen3_tts",
    "interval": 5000,
    "on_active": null,
    "on_inactive": null,
    "on_error": null
  },
  "triggers": {
    "tray": true,
    "quick_launcher": true,
    "context_menu": {
      "enabled": true,
      "extensions": [
        ".txt",
        ".md",
        ".wav",
        ".mp3",
        ".flac",
        ".m4a",
        ".ogg"
      ],
      "scopes": []
    },
    "sidebar_widget": null
  },
  "ui": {
    "enabled": true,
    "framework": "qt",
    "shared_theme": "contexthub"
  }
}
